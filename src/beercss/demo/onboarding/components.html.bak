    <!-- Scripts -->
    <script src="/dist/beercss/khipu-beercss.min.js"></script>
    <script src="assets/showcase.js"></script>

    <script>
        function scrollToSection(sectionId) {
            const section = document.getElementById(sectionId);
            if (section) {
                section.scrollIntoView({ behavior: 'smooth', block: 'start' });

                // Update active pill
                document.querySelectorAll('.showcase-pill').forEach(pill => {
                    pill.classList.remove('active');
                });
                event.currentTarget.classList.add('active');
            }
        }

        function copyCode(codeId) {
            const codeElement = document.getElementById(codeId);
            if (!codeElement) return;

            const code = codeElement.textContent;
            const button = event.currentTarget;

            navigator.clipboard.writeText(code).then(() => {
                const originalHTML = button.innerHTML;
                button.innerHTML = '✅ Copied!';
                button.classList.add('success');

                setTimeout(() => {
                    button.innerHTML = originalHTML;
                    button.classList.remove('success');
                }, 2000);
            }).catch(err => {
                console.error('Failed to copy:', err);
                button.innerHTML = '❌ Failed';
                setTimeout(() => {
                    button.innerHTML = '📋 Copy';
                }, 2000);
            });
        }

        function selectCard(card) {
            card.parentElement.querySelectorAll('.kds-card-selector').forEach(c =>
                c.classList.remove('selected')
            );
            card.classList.add('selected');
        }

        function selectBank(item) {
            document.querySelectorAll('.kds-bank-item').forEach(b =>
                b.classList.remove('selected')
            );
            item.classList.add('selected');
        }
    </script>
