# Enforce Node.js version specified in package.json engines
engine-strict=true

# Save exact versions in package.json (no ^ or ~)
save-exact=true

# Increase npm install speed
prefer-offline=true
progress=true

# AWS CodeArtifact registry (configured via publishConfig in package.json)
# To authenticate: aws codeartifact login --tool npm --domain khipu --repository npm-packages
