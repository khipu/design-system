# Use public npmjs.org registry for dependencies (overrides global CodeArtifact config)
registry=https://registry.npmjs.org/

# Enforce Node.js version specified in package.json engines
engine-strict=true

# Save exact versions in package.json (no ^ or ~)
save-exact=true

# Increase npm install speed
prefer-offline=true
progress=true

# Registry configuration
# Publishes to npmjs.org (public registry) - configured via publishConfig in package.json
# See docs/BUILD_PUBLISHING.md for details
